// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Category {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  type          CategoryType
  description   String?
  image         String?
  imageAlt      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subcategories Subcategory[]

  @@map("categories")
}

model Subcategory {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  categoryType CategoryType
  description  String?
  image        String?
  imageAlt     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  products     Product[]
  category     Category?    @relation(fields: [categoryId], references: [id])
  categoryId   String?

  @@map("subcategories")
}

model Article {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  excerpt          String?
  content          String        @db.Text
  featuredImage    String?
  featuredImageAlt String?
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  status           ArticleStatus @default(DRAFT)
  publishedAt      DateTime?
  author           Author?       @relation(fields: [authorId], references: [id])
  authorId         String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("articles")
}

model Author {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  title       String?
  bio         String?
  expertise   String?
  avatar      String?
  avatarAlt   String?
  website     String?
  twitter     String?
  linkedin    String?
  reviewCount Int?
  rating      Float?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
  articles    Article[]

  @@map("authors")
}

model Product {
  id                  String       @id @default(cuid())
  name                String
  slug                String       @unique
  price               Float
  categoryType        CategoryType
  shortDescription    String
  detailedDescription String
  keyFeatures         String?
  metaTitle           String?
  metaDescription     String?
  image               String
  imageAlt            String?
  featuredImage       String
  featuredImageAlt    String?
  readMoreLink        String?
  buyNowLink          String?
  author              Author?      @relation(fields: [authorId], references: [id])
  authorId            String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  subcategory         Subcategory  @relation(fields: [subcategoryId], references: [id])
  subcategoryId       String

  ingredients Ingredient[] @relation("ProductIngredients")

  @@map("products")
}

model Ingredient {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  keyFeatures String?   @db.Text
  image       String?
  imageAlt    String?
  products    Product[] @relation("ProductIngredients")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("ingredients")
}

model HeroSettings {
  id                 String         @id @default(cuid())
  title              String
  subtitle           String?
  description        String
  backgroundImage    String?
  backgroundType     BackgroundType @default(GRADIENT)
  gradientFrom       String         @default("#16A34A")
  gradientVia        String         @default("#15803D")
  gradientTo         String         @default("#14532D")
  textColor          String         @default("#FFFFFF")
  primaryColor       String         @default("#007BFF")
  ctaColor           String         @default("#FF6600")
  accentColor        String         @default("#28A745")
  overlayOpacity     Int            @default(30)
  backgroundPosition String         @default("center")
  backgroundSize     String         @default("cover")
  buyNowLink         String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("hero_settings")
}

model Image {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  data         Bytes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("images")
}

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?
  content     String   @db.Text
  avatar      String?
  rating      Int      @default(5)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED

  @@map("article_status")
}

enum UserRole {
  ADMIN
  USER

  @@map("user_role")
}

enum CategoryType {
  NUTRA
  ECOM

  @@map("category_type")
}

enum BackgroundType {
  GRADIENT
  IMAGE

  @@map("background_type")
}
